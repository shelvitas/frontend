echo '🏗️👷 Styling, testing and building your project before committing'

# Check TypeScript types
pnpm tsc --noEmit ||
(
    echo '🤡😂❌🤡 Failed Type check. 🤡😂❌🤡
            Are you seriously trying to write that? Make the changes required above.'
    false;
)

# Check ESLint Standards
pnpm lint:fix ||
(
    echo '😤🏀👋😤 Get that weak shit out of here! 😤🏀👋😤
            ESLint Check Failed. Make the required changes listed above, add changes and try to commit again.'
    false;
)

# Check Prettier standards
pnpm format:fix ||
(
    echo '🤢🤮🤢🤮 Its FOKING RAW - Your styling looks disgusting. 🤢🤮🤢🤮
            Prettier Check Failed. Run pnpm format:fix, add changes and try commit again.'
    false;
)

# Run tests
pnpm test ||
(
    echo '❌🧪💀❌ Tests failed! Your code is broken. ❌🧪💀❌
            Fix the failing tests above before you even think about committing.'
    false;
)

# If everything passes... Now we can commit
echo '🤔🤔🤔🤔... Alright.... Code looks good to me... Trying to build now. 🤔🤔🤔🤔'

pnpm build ||
(
    echo '❌👷🔨❌ Better call Bob... Because your build failed ❌👷🔨❌
            Next build failed: View the errors above to see why.'
    false;
)

# If everything passes... Now we can commit
echo '✅✅✅✅ You win this time... I am committing this now. ✅✅✅✅'
